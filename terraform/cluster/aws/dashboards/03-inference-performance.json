      "targets": [
        {"_source": "HttpErrorRateByStatusClass", "datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (status_code) (rate(http_requests_total{namespace=~\"$namespace\",service=~\"$service\",status_code=~\"4..|5..\"}[5m]))", "legendFormat": "{{status_code}}", "refId": "A"}
      ],
      "title": "Error Rate by Status",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
